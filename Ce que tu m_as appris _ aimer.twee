:: StoryStylesheet [stylesheet] {"position":"0,400","size":"100,100"}

@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap');

tw-story {
  background-color: #0a0a0c;
}

tw-passage {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 1.18em;
  line-height: 1.95;
  max-width: 660px;
  margin: 0 auto;
  padding: 4em 2em;
  color: #e6ddd4;
  transition: color 4s ease;
}

tw-passage a {
  color: #b89aaa;
  text-decoration: none;
  border-bottom: 1px solid rgba(184,154,170,0.25);
  transition: color 0.4s, border-color 0.4s;
}

tw-passage a:hover {
  color: #d4b8c8;
  border-bottom-color: rgba(212,184,200,0.6);
}

tw-passage em {
  color: #c4b8b0;
  font-style: italic;
}

tw-passage strong {
  font-weight: 500;
  color: #e6ddd4;
}

tw-passage hr {
  border: none;
  border-top: 1px solid rgba(184,154,170,0.15);
  margin: 2.5em auto;
  width: 35%;
}

tw-passage strong em,
tw-passage em strong {
  color: #b89aaa;
  font-size: 1.05em;
  letter-spacing: 0.08em;
}

/* Fins */
tw-passage p:last-child strong {
  display: block;
  margin-top: 3em;
  padding-top: 1.5em;
  border-top: 1px solid rgba(184,154,170,0.2);
  font-size: 0.8em;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #b89aaa;
  text-align: center;
  font-weight: 400;
}

